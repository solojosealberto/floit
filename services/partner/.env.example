PORT=4013
# Local: omit DATABASE_URL → SQLite en services/partner/data/partner.sqlite
# Staging/prod (Neon): postgresql://...@.../partner?sslmode=require
# DATABASE_URL=
DATABASE_SYNC=true
CATALOG_SERVICE_URL=http://127.0.0.1:4010
PARTNER_TO_CATALOG_INTERNAL_TOKEN=change-me-same-as-catalog-internal
PARTNER_TO_LEADS_INTERNAL_TOKEN=change-me-same-as-leads-internal
ADMIN_AUTH_REQUIRE_OIDC=false
PARTNER_AUTH_REQUIRE_OIDC=false
ADMIN_OIDC_ISSUER=
PARTNER_OIDC_ISSUER=
ADMIN_OIDC_AUDIENCE=floit-admin
PARTNER_OIDC_AUDIENCE=floit-partner
ADMIN_CATALOG_DELEGATE_EMAIL=ops@quegym.com
