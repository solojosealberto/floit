PORT=4012
# Local: omit DATABASE_URL → SQLite en services/leads/data/leads.sqlite
# Staging/prod (Neon): postgresql://...@.../leads?sslmode=require
# DATABASE_URL=
DATABASE_SYNC=true
LEADS_INTERNAL_API_TOKEN=change-me
ADMIN_AUTH_REQUIRE_OIDC=false
ADMIN_OIDC_ISSUER=
ADMIN_OIDC_AUDIENCE=floit-admin
ANALYTICS_SERVICE_URL=http://127.0.0.1:4014
